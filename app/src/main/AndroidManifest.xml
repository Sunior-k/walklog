<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Health Connect: 걸음 수 읽기 권한 -->
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    <!-- WorkManager 등 백그라운드에서 HC 데이터를 읽기 위한 권한 (Android 14+ 필수) -->
    <uses-permission android:name="android.permission.health.READ_HEALTH_DATA_IN_BACKGROUND" />

    <!-- 기상청 날씨 API 호출 -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- 알림 (API 33+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
        Health Connect 앱 패키지 가시성.
        Android 11(API 30)+ 에서 HealthConnectClient.getSdkStatus() 등
        패키지 조회를 위해 필요.
    -->
    <queries>
        <package android:name="com.google.android.apps.healthdata" />
        <intent>
            <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
            <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
        </intent>
    </queries>

    <application
        android:name=".WalkLogApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:enableOnBackInvokedCallback="true"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.walklog">

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!--
            WorkManager 자동 초기화 비활성화.
            WalkLogApplication.workManagerConfiguration 에서 HiltWorkerFactory 를 직접 주입한다.
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <receiver
            android:name="com.river.walklog.feature.home.notification.PeakHourAlarmReceiver"
            android:exported="false" />

        <!-- 메인 Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.WalkLog.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            Health Connect 개인정보 처리방침 화면 진입점.
            Health Connect 정책: 권한을 요청하는 앱은 개인정보 처리방침으로
            연결되는 Activity 를 반드시 선언해야 한다.
        -->
        <activity-alias
            android:name=".HealthConnectPrivacyRationaleActivity"
            android:exported="true"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
            </intent-filter>
        </activity-alias>

        <!--
            Android 14+ Health Connect 권한 화면 진입점.
            이 alias 가 없으면 READ_STEPS 요청 시 시스템이 권한 다이얼로그를
            표시하지 못하는 기기가 있다.
        -->
        <activity-alias
            android:name=".HealthConnectPermissionUsageActivity"
            android:exported="true"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>

    </application>

</manifest>
