<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/walklog_background"
    android:orientation="horizontal">

    <!-- 1열 패널 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">

        <!-- 월 네비게이션 헤더 -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/month_header"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:paddingHorizontal="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btn_prev_month"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="이전 달"
                android:src="@drawable/ic_chevron_left"
                android:tint="@color/walklog_gray_400"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_month_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textAppearance="@style/WalkLog.TextAppearance.SubTypography9B"
                android:textColor="@color/walklog_text_primary"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btn_next_month"
                app:layout_constraintStart_toEndOf="@id/btn_prev_month"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="2026년 4월" />

            <ImageButton
                android:id="@+id/btn_next_month"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="다음 달"
                android:src="@drawable/ic_chevron_right"
                android:tint="@color/walklog_gray_400"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- 월간 통계 -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/stats_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@color/walklog_surface_variant"
            android:paddingHorizontal="20dp"
            android:paddingVertical="14dp"
            android:elevation="2dp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/month_header"
            tools:visibility="visible">

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/stats_center_guideline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.5" />

            <TextView
                android:id="@+id/tv_total_steps_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="이달 총 걸음"
                android:textAppearance="@style/WalkLog.TextAppearance.SubTypography12R"
                android:textColor="@color/walklog_text_secondary"
                app:layout_constraintEnd_toStartOf="@id/stats_center_guideline"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_total_steps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:textAppearance="@style/WalkLog.TextAppearance.SubTypography9B"
                android:textColor="@color/walklog_text_primary"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="@id/tv_total_steps_label"
                app:layout_constraintStart_toStartOf="@id/tv_total_steps_label"
                app:layout_constraintTop_toBottomOf="@id/tv_total_steps_label"
                tools:text="128,450 보" />

            <View
                android:id="@+id/stats_divider"
                android:layout_width="1dp"
                android:layout_height="0dp"
                android:background="@color/walklog_gray_200"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="@id/stats_center_guideline"
                app:layout_constraintStart_toStartOf="@id/stats_center_guideline"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_achievement_rate_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="목표 달성률"
                android:textAppearance="@style/WalkLog.TextAppearance.SubTypography12R"
                android:textColor="@color/walklog_text_secondary"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/stats_center_guideline"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_achievement_rate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:textAppearance="@style/WalkLog.TextAppearance.SubTypography9B"
                android:textColor="@color/walklog_primary"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="@id/tv_achievement_rate_label"
                app:layout_constraintStart_toStartOf="@id/tv_achievement_rate_label"
                app:layout_constraintTop_toBottomOf="@id/tv_achievement_rate_label"
                tools:text="72%" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- 캘린더 그리드 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_calendar"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:clipToPadding="false"
            android:paddingHorizontal="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/stats_container" />

        <!-- 로딩 인디케이터 -->
        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/month_header"
            tools:visibility="visible" />

        <!-- 빈 상태 -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/empty_state"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/stats_container">

            <TextView
                android:id="@+id/tv_empty_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📭"
                android:textSize="48sp"
                app:layout_constraintBottom_toTopOf="@id/tv_empty_title"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_chainStyle="packed" />

            <TextView
                android:id="@+id/tv_empty_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="이번 달 걸음 기록이 없어요"
                android:textAppearance="@style/WalkLog.TextAppearance.Typography6R"
                android:textColor="@color/walklog_text_secondary"
                app:layout_constraintBottom_toTopOf="@id/tv_empty_description"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_empty_icon" />

            <TextView
                android:id="@+id/tv_empty_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="걸음 수를 측정하면 여기에 표시돼요"
                android:textAppearance="@style/WalkLog.TextAppearance.Typography7R"
                android:textColor="@color/walklog_gray_400"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_empty_title" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="@color/walklog_gray_200" />

    <!-- 2열 패널 -->
    <LinearLayout
        android:id="@+id/selected_day_container"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp"
        android:visibility="gone"
        tools:visibility="visible">

        <!-- 날짜 + 달성 칩 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_selected_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="@style/WalkLog.TextAppearance.Typography7R"
                android:textColor="@color/walklog_text_secondary"
                tools:text="4월 23일 (목)" />

            <TextView
                android:id="@+id/tv_selected_target_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textAppearance="@style/WalkLog.TextAppearance.SubTypography12B"
                tools:text="목표 달성" />

        </LinearLayout>

        <!-- 데이터 있는 경우 -->
        <LinearLayout
            android:id="@+id/group_has_data"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 걸음 수 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="bottom"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_selected_steps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/WalkLog.TextAppearance.Display1B"
                    android:textColor="@color/walklog_text_primary"
                    tools:text="8,420" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:layout_marginBottom="8dp"
                    android:text="보"
                    android:textAppearance="@style/WalkLog.TextAppearance.SubTypography10R"
                    android:textColor="@color/walklog_text_secondary" />

            </LinearLayout>

            <!-- 목표 프로그레스 바 -->
            <ProgressBar
                android:id="@+id/pb_goal_progress"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="5dp"
                android:layout_marginTop="10dp"
                android:max="100"
                tools:progress="72" />

            <!-- 비교 텍스트 -->
            <TextView
                android:id="@+id/tv_selected_comparison"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textAppearance="@style/WalkLog.TextAppearance.SubTypography12R"
                tools:text="↑ 전날보다 +1,200보" />

            <!-- 지표 카드 -->
            <LinearLayout
                android:id="@+id/selected_metrics_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <!-- 칼로리 카드 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_metric_card_warm"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="15dp"
                            android:layout_height="15dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_fire"
                            android:tint="@color/walklog_primary_dark" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="5dp"
                            android:text="칼로리"
                            android:textAppearance="@style/WalkLog.TextAppearance.SubTypography13R"
                            android:textColor="@color/walklog_primary_dark" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_selected_calories"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textAppearance="@style/WalkLog.TextAppearance.Typography4B"
                        android:textColor="@color/walklog_text_primary"
                        tools:text="336 kcal" />

                </LinearLayout>

                <View
                    android:layout_width="8dp"
                    android:layout_height="0dp" />

                <!-- 거리 카드 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_metric_card_cool"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="15dp"
                            android:layout_height="15dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_distance"
                            android:tint="@color/walklog_secondary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="5dp"
                            android:text="거리"
                            android:textAppearance="@style/WalkLog.TextAppearance.SubTypography13R"
                            android:textColor="@color/walklog_secondary" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_selected_distance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textAppearance="@style/WalkLog.TextAppearance.Typography4B"
                        android:textColor="@color/walklog_text_primary"
                        tools:text="6.3 km" />

                </LinearLayout>

            </LinearLayout>

            <!-- 선택한 요일 인사이트 -->
            <LinearLayout
                android:id="@+id/group_selected_insight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_selected_insight_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:visibility="gone"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_selected_insight_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Daily Insight"
                        android:textAppearance="@style/WalkLog.TextAppearance.SubTypography12B"
                        android:textColor="@color/walklog_text_secondary" />

                    <TextView
                        android:id="@+id/tv_selected_month_rank"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_selected_insight_badge"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:textAppearance="@style/WalkLog.TextAppearance.SubTypography12B"
                        android:textColor="@color/walklog_static_black"
                        tools:text="이번 달 3위" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tv_selected_insight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:textAppearance="@style/WalkLog.TextAppearance.Typography6B"
                    android:textColor="@color/walklog_text_primary"
                    tools:text="목표를 달성했고 전날보다 1,200보 더 걸었어요" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_selected_insight_metric"
                        android:orientation="vertical"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="걸음"
                            android:textAppearance="@style/WalkLog.TextAppearance.SubTypography13R"
                            android:textColor="@color/walklog_text_secondary" />

                        <TextView
                            android:id="@+id/tv_selected_insight_steps"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textAppearance="@style/WalkLog.TextAppearance.Typography6B"
                            android:textColor="@color/walklog_text_primary"
                            tools:text="8,420보" />

                    </LinearLayout>

                    <View
                        android:layout_width="10dp"
                        android:layout_height="0dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_selected_insight_metric"
                        android:orientation="vertical"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="목표"
                            android:textAppearance="@style/WalkLog.TextAppearance.SubTypography13R"
                            android:textColor="@color/walklog_text_secondary" />

                        <TextView
                            android:id="@+id/tv_selected_insight_goal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textAppearance="@style/WalkLog.TextAppearance.Typography6B"
                            android:textColor="@color/walklog_primary"
                            tools:text="84%" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- 선택한 요일 타임라인 -->
            <LinearLayout
                android:id="@+id/group_selected_timeline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_selected_day_panel"
                android:orientation="vertical"
                android:padding="18dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="선택일 타임라인"
                    android:textAppearance="@style/WalkLog.TextAppearance.Typography6B"
                    android:textColor="@color/walklog_text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="시간대별 걸음 분포"
                    android:textAppearance="@style/WalkLog.TextAppearance.SubTypography12R"
                    android:textColor="@color/walklog_text_secondary" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_timeline_morning_label"
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:text="오전"
                            android:textAppearance="@style/WalkLog.TextAppearance.SubTypography12B"
                            android:textColor="@color/walklog_text_primary" />

                        <ProgressBar
                            android:id="@+id/pb_timeline_morning"
                            style="@android:style/Widget.ProgressBar.Horizontal"
                            android:layout_width="0dp"
                            android:layout_height="7dp"
                            android:layout_marginHorizontal="10dp"
                            android:layout_weight="1"
                            android:max="100"
                            tools:progress="46" />

                        <TextView
                            android:id="@+id/tv_timeline_morning_steps"
                            android:layout_width="64dp"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:textAppearance="@style/WalkLog.TextAppearance.SubTypography12R"
                            android:textColor="@color/walklog_text_secondary"
                            tools:text="2,320보" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_timeline_afternoon_label"
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:text="오후"
                            android:textAppearance="@style/WalkLog.TextAppearance.SubTypography12B"
                            android:textColor="@color/walklog_text_primary" />

                        <ProgressBar
                            android:id="@+id/pb_timeline_afternoon"
                            style="@android:style/Widget.ProgressBar.Horizontal"
                            android:layout_width="0dp"
                            android:layout_height="7dp"
                            android:layout_marginHorizontal="10dp"
                            android:layout_weight="1"
                            android:max="100"
                            tools:progress="100" />

                        <TextView
                            android:id="@+id/tv_timeline_afternoon_steps"
                            android:layout_width="64dp"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:textAppearance="@style/WalkLog.TextAppearance.SubTypography12R"
                            android:textColor="@color/walklog_text_secondary"
                            tools:text="4,980보" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_timeline_evening_label"
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:text="저녁"
                            android:textAppearance="@style/WalkLog.TextAppearance.SubTypography12B"
                            android:textColor="@color/walklog_text_primary" />

                        <ProgressBar
                            android:id="@+id/pb_timeline_evening"
                            style="@android:style/Widget.ProgressBar.Horizontal"
                            android:layout_width="0dp"
                            android:layout_height="7dp"
                            android:layout_marginHorizontal="10dp"
                            android:layout_weight="1"
                            android:max="100"
                            tools:progress="58" />

                        <TextView
                            android:id="@+id/tv_timeline_evening_steps"
                            android:layout_width="64dp"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:textAppearance="@style/WalkLog.TextAppearance.SubTypography12R"
                            android:textColor="@color/walklog_text_secondary"
                            tools:text="2,870보" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- 데이터 없을 때 -->
        <LinearLayout
            android:id="@+id/group_no_data"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="20dp"
            android:paddingBottom="8dp"
            android:visibility="gone"
            tools:visibility="gone">

            <FrameLayout
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_empty_icon_circle">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_history_steps"
                    android:tint="@color/walklog_gray_300" />

            </FrameLayout>

            <TextView
                android:id="@+id/tv_no_data_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:textAppearance="@style/WalkLog.TextAppearance.Typography6B"
                android:textColor="@color/walklog_text_primary"
                tools:text="이날은 기록이 없었어요" />

            <TextView
                android:id="@+id/tv_no_data_sub_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textAppearance="@style/WalkLog.TextAppearance.SubTypography12R"
                android:textColor="@color/walklog_gray_400"
                tools:text="다음엔 더 많이 걸어봐요" />

        </LinearLayout>

        <!-- 날짜 미선택 안내 -->
        <LinearLayout
            android:id="@+id/group_select_prompt"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅"
                android:textSize="48sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="날짜를 선택해 주세요"
                android:textAppearance="@style/WalkLog.TextAppearance.Typography6R"
                android:textColor="@color/walklog_text_secondary" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
