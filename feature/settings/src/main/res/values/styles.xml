<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="WalkLogSettingsSectionLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingHorizontal">4dp</item>
        <item name="android:paddingVertical">8dp</item>
        <item name="android:textColor">@color/walklog_text_secondary</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="WalkLogSettingsCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/bg_settings_card</item>
        <item name="android:padding">16dp</item>
    </style>

    <style name="WalkLogSettingsPrimaryText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/walklog_text_primary</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="WalkLogSettingsRangeText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/walklog_text_secondary</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="WalkLogSettingsValueTextPrimary">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/walklog_primary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="WalkLogSettingsValueTextSecondary">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/walklog_secondary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="WalkLogSettingsRadioButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:buttonTint">@color/walklog_primary</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:textColor">@color/walklog_text_primary</item>
        <item name="android:textSize">14sp</item>
    </style>

</resources>
